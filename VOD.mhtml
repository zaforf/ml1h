.jiggle.transition { animation-duration: 750ms; animation-name: jiggle; }

.transition.glow { animation-duration: 2s; animation-timing-function: cubic=
-bezier(0.19, 1, 0.22, 1); }

.transition.glow { animation-name: glow; }

@-webkit-keyframes flash {=20
  0%, 100%, 50% { opacity: 1; }
  25%, 75% { opacity: 0; }
}

@keyframes flash {=20
  0%, 100%, 50% { opacity: 1; }
  25%, 75% { opacity: 0; }
}

@-webkit-keyframes shake {=20
  0%, 100% { transform: translateX(0px); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-10px); }
  20%, 40%, 60%, 80% { transform: translateX(10px); }
}

@keyframes shake {=20
  0%, 100% { transform: translateX(0px); }
  10%, 30%, 50%, 70%, 90% { transform: translateX(-10px); }
  20%, 40%, 60%, 80% { transform: translateX(10px); }
}

@-webkit-keyframes bounce {=20
  0%, 100%, 20%, 50%, 80% { transform: translateY(0px); }
  40% { transform: translateY(-30px); }
  60% { transform: translateY(-15px); }
}

@keyframes bounce {=20
  0%, 100%, 20%, 50%, 80% { transform: translateY(0px); }
  40% { transform: translateY(-30px); }
  60% { transform: translateY(-15px); }
}

@-webkit-keyframes tada {=20
  0% { transform: scale(1); }
  10%, 20% { transform: scale(0.9) rotate(-3deg); }
  30%, 50%, 70%, 90% { transform: scale(1.1) rotate(3deg); }
  40%, 60%, 80% { transform: scale(1.1) rotate(-3deg); }
  100% { transform: scale(1) rotate(0deg); }
}

@keyframes tada {=20
  0% { transform: scale(1); }
  10%, 20% { transform: scale(0.9) rotate(-3deg); }
  30%, 50%, 70%, 90% { transform: scale(1.1) rotate(3deg); }
  40%, 60%, 80% { transform: scale(1.1) rotate(-3deg); }
  100% { transform: scale(1) rotate(0deg); }
}

@-webkit-keyframes pulse {=20
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(0.9); opacity: 0.7; }
  100% { transform: scale(1); opacity: 1; }
}

@keyframes pulse {=20
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(0.9); opacity: 0.7; }
  100% { transform: scale(1); opacity: 1; }
}

@-webkit-keyframes jiggle {=20
